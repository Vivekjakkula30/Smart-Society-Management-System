# Smart Society Management System - Environment Configuration

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# MySQL Database Connection
DB_HOST=localhost
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=smart_society
DB_PORT=3306

# Database Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# ==========================================
# JWT CONFIGURATION
# ==========================================

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your_super_secure_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# ==========================================
# PAYMENT GATEWAY CONFIGURATION (Optional)
# ==========================================

# Razorpay Configuration (if using Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe Configuration (if using Stripe)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email Settings
FROM_EMAIL=noreply@smartsociety.com
FROM_NAME=Smart Society Management

# ==========================================
# SMS CONFIGURATION (Optional)
# ==========================================

# Twilio Configuration for SMS Notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ==========================================
# FILE UPLOAD CONFIGURATION (Optional)
# ==========================================

# File Upload Settings
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==========================================
# LOGGING CONFIGURATION
# ==========================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Log File Path
LOG_FILE=./logs/app.log

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# EXTERNAL API KEYS (Optional)
# ==========================================

# Weather API (for weather-related notices)
WEATHER_API_KEY=your_weather_api_key

# Google Maps API (for location services)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ==========================================
# BACKUP CONFIGURATION
# ==========================================

# Database Backup Settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=24  # hours
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# ==========================================
# MONITORING & ANALYTICS
# ==========================================

# Application Monitoring
MONITORING_ENABLED=false
MONITORING_ENDPOINT=https://your-monitoring-service.com

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=your_analytics_tracking_id

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

# Enable Debug Mode
DEBUG=true

# Enable API Documentation
API_DOCS_ENABLED=true

# Enable Swagger UI
SWAGGER_ENABLED=true

# ==========================================
# PRODUCTION OVERRIDES
# ==========================================
# When NODE_ENV=production, these settings take precedence

# Production Database (if different from development)
# PROD_DB_HOST=your_production_db_host
# PROD_DB_USER=your_production_db_user
# PROD_DB_PASSWORD=your_production_db_password

# Production Redis (if using Redis for sessions)
# REDIS_URL=redis://your_redis_url:6379

# ==========================================
# IMPORTANT SECURITY NOTES
# ==========================================
#
# 1. NEVER commit the actual .env file to version control
# 2. Always use strong, unique passwords and secrets
# 3. Rotate secrets regularly in production
# 4. Use environment-specific secrets (dev/staging/prod)
# 5. Consider using a secret management service like AWS Secrets Manager
# 6. Enable encryption at rest for sensitive configuration
#
# ==========================================
